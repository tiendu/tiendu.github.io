---
import SystemPageLayout from "../layouts/SystemPageLayout.astro";
---

<SystemPageLayout
  title="404"
  moduleCode="RECORD-NOT-FOUND"
  description="The requested route may have moved, expired, or never existed."
  counter="ROUTE FAILED"
>
  <section class="system-error-panel" aria-labelledby="error-heading">
    <p class="system-section-code">ERROR / UNRESOLVED PATH</p>
    <h2 id="error-heading">No record exists at this address.</h2>
    <p>
      Return to the terminal, inspect the log archive, or choose another system
      module.
    </p>
    <nav aria-label="Recovery links">
      <a href="/">OPEN TERMINAL</a>
      <a href="/posts/">OPEN LOG ARCHIVE</a>
    </nav>
  </section>
</SystemPageLayout>
