---
import BaseLayout from "../layouts/BaseLayout.astro";
import SnakeGame from "../components/SnakeGame.astro";
import InvadersGame from "../components/InvadersGame.astro";
---

<BaseLayout>
  <section class="landing-wrapper" aria-labelledby="home-title">
    <script is:inline data-astro-rerun>
      document.currentScript?.parentElement?.classList.add(
        "terminal-typing-enabled",
      );
    </script>


    <div class="terminal-card">
      <div class="terminal-header" aria-hidden="true">
        <span>
          TIENDU@HOME / <span data-terminal-mode>PROFILE</span>
        </span>

        <span class="terminal-status" data-terminal-status>
          <span class="status-light" aria-hidden="true"></span>
          <span data-status-label>STANDBY</span>
        </span>
      </div>

      <div class="terminal-screen" data-terminal-screen>
        <div class="terminal-content">
          <p class="command-line" aria-label="Terminal command: profile">
            <span class="typed-command">
              <span class="prompt">TIENDU@HOME</span>
              <span class="path">:~$</span>
              <span> PROFILE</span>
            </span>
            <span class="block-cursor" aria-hidden="true"></span>
          </p>

          <div class="profile-view" data-profile-view>
            <div class="output-stage" data-profile-copy>
              <div class="output-measure" aria-hidden="true">
                <p class="terminal-title">I'M TIEN.</p>

                <p>
                  I work across Linux systems, cloud infrastructure, distributed
                  workloads, monitoring, automation, and production reliability.
                </p>

                <p>
                  This site is where I keep technical notes, engineering references,
                  small projects, and lessons from systems that failed in interesting
                  ways.
                </p>
              </div>

              <section class="output" aria-busy="false">
                <h1
                  id="home-title"
                  class="terminal-title"
                  data-terminal-line
                  data-speed="55"
                >
                  I'M TIEN.
                </h1>

                <p data-terminal-line data-speed="24">
                  I work across Linux systems, cloud infrastructure, distributed
                  workloads, monitoring, automation, and production reliability.
                </p>

                <p data-terminal-line data-speed="24">
                  This site is where I keep technical notes, engineering references,
                  small projects, and lessons from systems that failed in interesting
                  ways.
                </p>
              </section>
            </div>

            <p
              class="terminal-response"
              data-terminal-response
              aria-live="polite"
              hidden
            ></p>
          </div>

          <SnakeGame />

          <div
            class="snake-mobile-controls"
            data-snake-mobile-controls
            aria-label="Snake game controls"
          >
            <div class="snake-mobile-actions">
              <button type="button" data-snake-action="pause">PAUSE</button>
              <button type="button" data-snake-action="restart">RESTART</button>
              <button type="button" data-snake-action="exit">EXIT</button>
            </div>

            <p class="snake-mobile-help">SWIPE OR USE CONTROLS</p>
          </div>

          <InvadersGame />

          <div
            class="invaders-mobile-controls"
            data-invaders-mobile-controls
            aria-label="Space Invaders game controls"
          >
            <div class="invaders-mobile-actions">
              <button type="button" data-invaders-action="pause">PAUSE</button>
              <button type="button" data-invaders-action="restart">RESTART</button>
              <button type="button" data-invaders-action="exit">EXIT</button>
            </div>

            <p class="invaders-mobile-help">MOVE · FIRE · SURVIVE</p>
          </div>

          <form class="terminal-shell" data-terminal-shell hidden>
            <span class="prompt">TIENDU@HOME</span>
            <span class="path">:~$</span>
            <span class="terminal-shell-entry">
              <input
                class="terminal-shell-input"
                data-terminal-input
                type="text"
                maxlength="16"
                autocomplete="off"
                autocapitalize="characters"
                spellcheck="false"
                enterkeyhint="go"
                aria-label="Terminal command"
                aria-describedby="terminal-input-warning"
              />
              <span class="shell-block-cursor" aria-hidden="true"></span>
            </span>
          </form>

          <p
            id="terminal-input-warning"
            class="terminal-input-warning"
            data-terminal-input-warning
            role="status"
            aria-live="polite"
            hidden
          >
            MAX 16 CHARACTERS · PRESS ENTER OR BACKSPACE
          </p>

          <p class="terminal-footer" data-terminal-footer aria-hidden="true">
            <span data-footer-state>BOOTING</span>
            <span>
              SESSION <span data-session-count>01</span>
            </span>
          </p>
        </div>
      </div>
    </div>

    <script is:inline data-astro-rerun>
      (() => {
        const wrapper = document.currentScript?.closest(".landing-wrapper");

        if (!wrapper || wrapper.dataset.animationStarted === "true") {
          return;
        }

        wrapper.dataset.animationStarted = "true";

        const sessionCounter = wrapper.querySelector("[data-session-count]");
        const SESSION_STORAGE_KEY = "tiendu-home-session";
        const SESSION_TTL_MS = 24 * 60 * 60 * 1000;

        const updateSessionCounter = () => {
          const now = Date.now();
          let count = 1;

          try {
            const storedValue = window.localStorage.getItem(
              SESSION_STORAGE_KEY,
            );
            const storedSession = storedValue
              ? JSON.parse(storedValue)
              : null;
            const sessionIsValid =
              storedSession &&
              Number.isInteger(storedSession.count) &&
              typeof storedSession.expiresAt === "number" &&
              storedSession.expiresAt > now;

            const nextSession = sessionIsValid
              ? {
                  count: storedSession.count + 1,
                  expiresAt: storedSession.expiresAt,
                }
              : {
                  count: 1,
                  expiresAt: now + SESSION_TTL_MS,
                };

            window.localStorage.setItem(
              SESSION_STORAGE_KEY,
              JSON.stringify(nextSession),
            );

            count = nextSession.count;
          } catch {
            // Keep SESSION 01 when browser storage is unavailable.
          }

          if (sessionCounter) {
            sessionCounter.textContent = String(count).padStart(2, "0");
          }
        };

        updateSessionCounter();

        const greetings = [
          "Hey there! Thanks for stopping by!",
          "Hallo! Danke, dass du vorbeischaust!",
          "Bonjour ! Merci de votre visite !",
          "¡Hola! ¡Gracias por visitar!",
          "Olá! Obrigado pela visita!",
          "Ciao! Grazie della visita!",
          "Merhaba! Ziyaretiniz için teşekkürler!",
          "Привет! Спасибо за визит!",
          "Selamat datang! Terima kasih telah berkunjung!",
          "สวัสดี! ขอบคุณที่แวะมาเยี่ยมชม!",
          "नमस्ते! आने के लिए धन्यवाद!",
          "مرحبًا! شكرًا لزيارتك!",
          "안녕하세요! 방문해 주셔서 감사합니다!",
          "こんにちは！ご訪問ありがとうございます！",
          "你好！感谢你的到访！",
          "Xin chào! Cảm ơn bạn đã ghé thăm!",
        ];

        const output = wrapper.querySelector(".output");
        const profileView = wrapper.querySelector("[data-profile-view]");
        const profileCopy = wrapper.querySelector("[data-profile-copy]");
        const commandCursor = wrapper.querySelector(".block-cursor");
        const footer = wrapper.querySelector("[data-terminal-footer]");
        const footerState = wrapper.querySelector("[data-footer-state]");
        const typedCommand = wrapper.querySelector(".typed-command");
        const terminalStatus = wrapper.querySelector(
          "[data-terminal-status]",
        );
        const terminalMode = wrapper.querySelector("[data-terminal-mode]");
        const statusLabel = wrapper.querySelector("[data-status-label]");
        const shell = wrapper.querySelector("[data-terminal-shell]");
        const terminalInput = wrapper.querySelector("[data-terminal-input]");
        const inputWarning = wrapper.querySelector(
          "[data-terminal-input-warning]",
        );
        const response = wrapper.querySelector("[data-terminal-response]");
        const terminalScreen = wrapper.querySelector("[data-terminal-screen]");
        const snakeRoot = wrapper.querySelector("[data-snake-game]");
        const snakeOverlay = wrapper.querySelector("[data-snake-overlay]");
        const snakeState = wrapper.querySelector("[data-snake-state]");
        const snakeModeOutput = wrapper.querySelector("[data-snake-mode]");
        const snakeActionButtons = Array.from(
          wrapper.querySelectorAll("[data-snake-action]"),
        );
        const snakePauseButton = wrapper.querySelector(
          '[data-snake-action="pause"]',
        );
        const invadersRoot = wrapper.querySelector("[data-invaders-game]");
        const invadersOverlay = wrapper.querySelector("[data-invaders-overlay]");
        const invadersState = wrapper.querySelector("[data-invaders-state]");
        const invadersWave = wrapper.querySelector("[data-invaders-wave]");
        const invadersActionButtons = Array.from(
          wrapper.querySelectorAll("[data-invaders-action]"),
        );
        const invadersPauseButton = wrapper.querySelector(
          '[data-invaders-action="pause"]',
        );

        const reducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        );
        const finePointer = window.matchMedia("(pointer: fine)");

        const COMMAND_LENGTH_LIMIT = 16;

        let terminalIsOnline = false;
        let snakeIsActive = false;
        let invadersIsActive = false;

        const setText = (element, value) => {
          if (element) {
            element.textContent = value;
          }
        };

        const setTerminalOnline = () => {
          if (terminalIsOnline) {
            return;
          }

          terminalIsOnline = true;
          terminalStatus?.classList.add("is-online");
          setText(statusLabel, "ONLINE");
        };

        if (reducedMotion.matches) {
          setTerminalOnline();
        } else if (typedCommand) {
          typedCommand.addEventListener(
            "animationend",
            (event) => {
              if (event.animationName === "command-typing") {
                setTerminalOnline();
              }
            },
            { once: true },
          );

          window.setTimeout(setTerminalOnline, 1800);
        } else {
          setTerminalOnline();
        }

        const sleep = (milliseconds) =>
          new Promise((resolve) => window.setTimeout(resolve, milliseconds));

        const showResponse = (message) => {
          if (!response) {
            return;
          }

          response.textContent = message;
          response.hidden = false;
        };

        const clearResponse = () => {
          if (response) {
            response.textContent = "";
            response.hidden = true;
          }
        };

        const hideInputWarning = () => {
          inputWarning?.setAttribute("hidden", "");
          shell?.classList.remove("is-at-limit");
        };

        const showInputWarning = () => {
          inputWarning?.removeAttribute("hidden");
          shell?.classList.add("is-at-limit");
        };

        const resizeTerminalInput = () => {
          if (!(terminalInput instanceof HTMLInputElement)) {
            return;
          }

          const visibleCharacters = Math.min(
            terminalInput.value.length,
            COMMAND_LENGTH_LIMIT,
          );

          /*
           * Keep a little spare width for the final glyph. This prevents the
           * native input from horizontally scrolling its text and appearing
           * to jump left as the command approaches the limit.
           */
          const measuredWidth = Math.max(
            visibleCharacters + 1.25,
            1.25,
          );

          terminalInput.style.width = `${measuredWidth}ch`;
        };

        const revealShell = () => {
          commandCursor?.classList.add("cursor-hidden");

          if (shell) {
            shell.hidden = false;
          }

          resizeTerminalInput();
          footer?.classList.add("terminal-footer-visible");
          setText(footerState, "READY · TYPE HELP");

          if (finePointer.matches && terminalInput instanceof HTMLElement) {
            window.setTimeout(() => terminalInput.focus(), 0);
          }
        };

        let greetingIndex = Math.floor(Math.random() * greetings.length);

        const getNextGreeting = () => {
          const message = greetings[greetingIndex];
          greetingIndex = (greetingIndex + 1) % greetings.length;
          return message;
        };

        const typeLine = async (element, text) => {
          const speed = Number(element.dataset.speed ?? 24);

          element.style.visibility = "visible";
          element.classList.add("is-typing");

          for (const character of text) {
            element.textContent += character;

            if (
              character === "." ||
              character === "?" ||
              character === "!"
            ) {
              await sleep(speed * 5);
            } else if (
              character === "," ||
              character === ":" ||
              character === ";"
            ) {
              await sleep(speed * 2.5);
            } else {
              await sleep(speed);
            }
          }

          element.classList.remove("is-typing");
        };

        const startTerminalOutput = async () => {
          if (!output) {
            wrapper.classList.remove("terminal-typing-enabled");
            revealShell();
            return;
          }

          const lines = Array.from(
            output.querySelectorAll("[data-terminal-line]"),
          );

          if (reducedMotion.matches) {
            wrapper.classList.remove("terminal-typing-enabled");
            output.setAttribute("aria-busy", "false");
            revealShell();
            return;
          }

          const textByLine = lines.map((line) =>
            (line.textContent ?? "").replace(/\s+/g, " ").trim(),
          );

          output.setAttribute("aria-busy", "true");

          lines.forEach((line) => {
            line.textContent = "";
            line.style.visibility = "hidden";
          });

          await sleep(1850);
          commandCursor?.classList.add("cursor-dimmed");

          for (let index = 0; index < lines.length; index += 1) {
            await typeLine(lines[index], textByLine[index]);
            await sleep(index === 0 ? 420 : 650);
          }

          output.setAttribute("aria-busy", "false");
          wrapper.classList.remove("terminal-typing-enabled");
          revealShell();
        };

        const setPauseButtonState = (label, disabled = false) => {
          if (!(snakePauseButton instanceof HTMLButtonElement)) {
            return;
          }

          snakePauseButton.textContent = label;
          snakePauseButton.disabled = disabled;
          snakePauseButton.setAttribute(
            "aria-pressed",
            label === "RESUME" ? "true" : "false",
          );
        };

        const setInvadersPauseButtonState = (label, disabled = false) => {
          if (!(invadersPauseButton instanceof HTMLButtonElement)) {
            return;
          }

          invadersPauseButton.textContent = label;
          invadersPauseButton.disabled = disabled;
          invadersPauseButton.setAttribute(
            "aria-pressed",
            label === "RESUME" ? "true" : "false",
          );
        };

        const getSnakeMode = () => {
          const value = snakeModeOutput?.textContent?.trim().toUpperCase() ?? "";
          return value === "FREE" || value === "MAZE" ? value : "";
        };

        const setSnakeModeLabel = (mode) => {
          setText(terminalMode, mode ? `SNAKE / ${mode}` : "SNAKE");
        };

        const syncSnakeState = () => {
          if (!snakeIsActive) {
            return;
          }

          const state = snakeState?.textContent?.trim().toUpperCase() ?? "";
          const mode = getSnakeMode();
          const modePrefix = mode ? `${mode} MODE · ` : "";
          const overlayVisible = snakeOverlay ? !snakeOverlay.hidden : false;

          setSnakeModeLabel(mode);
          terminalStatus?.classList.remove("is-paused", "is-game-over");

          if (state === "SELECT MODE") {
            setText(statusLabel, "SELECT MODE");
            setText(footerState, "SELECT MODE · FREE OR MAZE");
            setPauseButtonState("PAUSE", true);
            return;
          }

          if (state === "PAUSED") {
            terminalStatus?.classList.add("is-paused");
            setText(statusLabel, "PAUSED");
            setText(footerState, `${modePrefix}GAME PAUSED`);
            setPauseButtonState("RESUME");
            return;
          }

          if (state === "GAME OVER" || state === "SYSTEM CLEARED") {
            terminalStatus?.classList.add("is-game-over");
            setText(statusLabel, state);
            setText(
              footerState,
              `${modePrefix}${state} · RESTART, CHANGE MODE, OR EXIT`,
            );
            setPauseButtonState("PAUSE", true);
            return;
          }

          if (state === "PRESS A DIRECTION") {
            setText(statusLabel, "READY");
            setText(
              footerState,
              finePointer.matches
                ? `${modePrefix}READY · ARROWS/WASD`
                : `${modePrefix}READY · USE CONTROLS`,
            );
            setPauseButtonState("PAUSE", true);
            return;
          }

          if (!overlayVisible) {
            setText(statusLabel, "RUNNING");
            setText(
              footerState,
              finePointer.matches
                ? `${modePrefix}ACTIVE · ESC EXIT`
                : `${modePrefix}ACTIVE · USE CONTROLS`,
            );
            setPauseButtonState("PAUSE");
          }
        };

        const openSnake = () => {
          snakeIsActive = true;
          wrapper.classList.add("snake-mode");

          if (profileView) {
            profileView.hidden = true;
          }

          if (shell) {
            shell.hidden = true;
          }

          clearResponse();
          setSnakeModeLabel("");
          setText(statusLabel, "SELECT MODE");
          setText(footerState, "SELECT MODE · FREE OR MAZE");
          setPauseButtonState("PAUSE", true);
          window.dispatchEvent(new CustomEvent("tiendu:snake-start"));
          window.setTimeout(syncSnakeState, 0);
        };

        const restoreProfile = (score = 0, highScore = 0) => {
          snakeIsActive = false;
          wrapper.classList.remove("snake-mode");
          terminalStatus?.classList.remove("is-paused", "is-game-over");
          setPauseButtonState("PAUSE");

          if (profileView) {
            profileView.hidden = false;
          }

          if (profileCopy) {
            profileCopy.hidden = false;
          }

          if (shell) {
            shell.hidden = false;
          }

          resizeTerminalInput();
          setText(terminalMode, "PROFILE");
          setText(statusLabel, "ONLINE");
          setText(footerState, "READY · TYPE HELP");
          showResponse(
            `SNAKE CLOSED · SCORE ${String(score).padStart(4, "0")} · HIGH ${String(highScore).padStart(4, "0")}`,
          );

          if (finePointer.matches && terminalInput instanceof HTMLElement) {
            window.setTimeout(() => terminalInput.focus(), 0);
          }
        };

        const syncInvadersState = () => {
          if (!invadersIsActive) {
            return;
          }

          const state =
            invadersState?.textContent?.trim().toUpperCase() ?? "";
          const waveLabel =
            invadersWave?.textContent?.trim().padStart(2, "0") ?? "01";
          const overlayVisible = invadersOverlay
            ? !invadersOverlay.hidden
            : false;

          setText(terminalMode, `INVADERS / WAVE ${waveLabel}`);
          terminalStatus?.classList.remove("is-paused", "is-game-over");

          if (state === "PAUSED") {
            terminalStatus?.classList.add("is-paused");
            setText(statusLabel, "PAUSED");
            setText(footerState, `WAVE ${waveLabel} · GAME PAUSED`);
            setInvadersPauseButtonState("RESUME");
            return;
          }

          if (state === "GAME OVER") {
            terminalStatus?.classList.add("is-game-over");
            setText(statusLabel, "GAME OVER");
            setText(
              footerState,
              `WAVE ${waveLabel} · GAME OVER · RESTART OR EXIT`,
            );
            setInvadersPauseButtonState("PAUSE", true);
            return;
          }

          if (state === "SHIP LOST") {
            terminalStatus?.classList.add("is-paused");
            setText(statusLabel, "SHIP LOST");
            setText(footerState, `WAVE ${waveLabel} · RECOVERING`);
            setInvadersPauseButtonState("PAUSE", true);
            return;
          }

          if (state.startsWith("WAVE ") && state.endsWith(" CLEARED")) {
            terminalStatus?.classList.add("is-paused");
            setText(statusLabel, "WAVE CLEAR");
            setText(footerState, `${state} · NEXT SIGNAL`);
            setInvadersPauseButtonState("PAUSE", true);
            return;
          }

          if (state === "PRESS FIRE OR MOVE") {
            setText(statusLabel, "READY");
            setText(
              footerState,
              finePointer.matches
                ? `WAVE ${waveLabel} · READY · A/D + SPACE`
                : `WAVE ${waveLabel} · READY · USE CONTROLS`,
            );
            setInvadersPauseButtonState("PAUSE", true);
            return;
          }

          if (!overlayVisible || state === "RUNNING") {
            setText(statusLabel, "RUNNING");
            setText(
              footerState,
              finePointer.matches
                ? `WAVE ${waveLabel} · ACTIVE · ESC EXIT`
                : `WAVE ${waveLabel} · ACTIVE · USE CONTROLS`,
            );
            setInvadersPauseButtonState("PAUSE");
          }
        };

        const openInvaders = () => {
          invadersIsActive = true;
          wrapper.classList.add("invaders-mode");

          if (profileView) {
            profileView.hidden = true;
          }

          if (shell) {
            shell.hidden = true;
          }

          clearResponse();
          setText(terminalMode, "INVADERS / WAVE 01");
          setText(statusLabel, "READY");
          setText(
            footerState,
            finePointer.matches
              ? "WAVE 01 · READY · A/D + SPACE"
              : "WAVE 01 · READY · USE CONTROLS",
          );
          setInvadersPauseButtonState("PAUSE", true);
          window.dispatchEvent(new CustomEvent("tiendu:invaders-start"));
          window.setTimeout(syncInvadersState, 0);
        };

        const restoreInvadersProfile = (
          score = 0,
          highScore = 0,
          wave = 1,
        ) => {
          invadersIsActive = false;
          wrapper.classList.remove("invaders-mode");
          terminalStatus?.classList.remove("is-paused", "is-game-over");
          setInvadersPauseButtonState("PAUSE");

          if (profileView) {
            profileView.hidden = false;
          }

          if (profileCopy) {
            profileCopy.hidden = false;
          }

          if (shell) {
            shell.hidden = false;
          }

          resizeTerminalInput();
          setText(terminalMode, "PROFILE");
          setText(statusLabel, "ONLINE");
          setText(footerState, "READY · TYPE HELP");
          showResponse(
            `INVADERS CLOSED · SCORE ${String(score).padStart(4, "0")} · HIGH ${String(highScore).padStart(4, "0")} · WAVE ${String(wave).padStart(2, "0")}`,
          );

          if (finePointer.matches && terminalInput instanceof HTMLElement) {
            window.setTimeout(() => terminalInput.focus(), 0);
          }
        };

        const runCommand = (rawCommand) => {
          const command = rawCommand.trim().toLowerCase();

          if (!command) {
            return;
          }

          if (command === "help") {
            showResponse(
              "COMMANDS: PROFILE · HELLO · POSTS · PROJECTS · TAGS · ABOUT · SNAKE · INVADERS · CLEAR",
            );
            return;
          }

          if (command === "hello" || command === "hi") {
            showResponse(getNextGreeting());
            return;
          }

          if (command === "profile" || command === "home") {
            if (profileCopy) {
              profileCopy.hidden = false;
            }
            showResponse("PROFILE DISPLAYED.");
            return;
          }

          if (command === "clear") {
            if (profileCopy) {
              profileCopy.hidden = true;
            }
            clearResponse();
            return;
          }

          if (command === "snake") {
            openSnake();
            return;
          }

          if (command === "invaders" || command === "invader") {
            openInvaders();
            return;
          }

          const routes = {
            posts: "/posts/",
            projects: "/projects/",
            tags: "/tags/",
            about: "/about/",
          };

          if (routes[command]) {
            window.location.assign(routes[command]);
            return;
          }

          showResponse(`COMMAND NOT FOUND: ${command.toUpperCase()} · TYPE HELP`);
        };

        terminalInput?.addEventListener("beforeinput", (event) => {
          if (
            !(terminalInput instanceof HTMLInputElement) ||
            !(event instanceof InputEvent) ||
            !event.inputType.startsWith("insert")
          ) {
            return;
          }

          const selectionStart =
            terminalInput.selectionStart ?? terminalInput.value.length;
          const selectionEnd =
            terminalInput.selectionEnd ?? terminalInput.value.length;
          const selectedCharacters = selectionEnd - selectionStart;
          const insertedCharacters = event.data?.length ?? 1;
          const resultingLength =
            terminalInput.value.length -
            selectedCharacters +
            insertedCharacters;

          if (resultingLength > COMMAND_LENGTH_LIMIT) {
            event.preventDefault();
            showInputWarning();
          }
        });

        terminalInput?.addEventListener("paste", (event) => {
          if (!(terminalInput instanceof HTMLInputElement)) {
            return;
          }

          const pastedText = event.clipboardData?.getData("text") ?? "";
          const selectionStart =
            terminalInput.selectionStart ?? terminalInput.value.length;
          const selectionEnd =
            terminalInput.selectionEnd ?? terminalInput.value.length;
          const selectedCharacters = selectionEnd - selectionStart;
          const resultingLength =
            terminalInput.value.length -
            selectedCharacters +
            pastedText.length;

          if (resultingLength > COMMAND_LENGTH_LIMIT) {
            event.preventDefault();
            showInputWarning();
          }
        });

        terminalInput?.addEventListener("keydown", (event) => {
          if (!(terminalInput instanceof HTMLInputElement)) {
            return;
          }

          if (event.key === "Backspace" || event.key === "Delete") {
            hideInputWarning();
            return;
          }

          const hasSelection =
            terminalInput.selectionStart !== terminalInput.selectionEnd;
          const isPrintableCharacter =
            event.key.length === 1 &&
            !event.ctrlKey &&
            !event.metaKey &&
            !event.altKey;

          if (
            isPrintableCharacter &&
            !hasSelection &&
            terminalInput.value.length >= COMMAND_LENGTH_LIMIT
          ) {
            event.preventDefault();
            showInputWarning();
          }
        });

        terminalInput?.addEventListener("input", () => {
          if (!(terminalInput instanceof HTMLInputElement)) {
            return;
          }

          if (terminalInput.value.length < COMMAND_LENGTH_LIMIT) {
            hideInputWarning();
          }

          resizeTerminalInput();
        });

        shell?.addEventListener("submit", (event) => {
          event.preventDefault();

          if (!(terminalInput instanceof HTMLInputElement)) {
            return;
          }

          const command = terminalInput.value;
          terminalInput.value = "";
          hideInputWarning();
          resizeTerminalInput();
          runCommand(command);
        });

        terminalScreen?.addEventListener("click", (event) => {
          if (
            snakeIsActive ||
            invadersIsActive ||
            !shell ||
            shell.hidden ||
            !(terminalInput instanceof HTMLInputElement)
          ) {
            return;
          }

          if (event.target instanceof HTMLButtonElement) {
            return;
          }

          terminalInput.focus();
        });

        snakeActionButtons.forEach((button) => {
          button.addEventListener("click", () => {
            const action = button.dataset.snakeAction;
            const keyByAction = {
              pause: "p",
              restart: "r",
              exit: "Escape",
            };
            const key = keyByAction[action];

            if (!key || !snakeIsActive) {
              return;
            }

            document.dispatchEvent(
              new KeyboardEvent("keydown", {
                key,
                bubbles: true,
                cancelable: true,
              }),
            );
          });
        });

        invadersActionButtons.forEach((button) => {
          button.addEventListener("click", () => {
            const action = button.dataset.invadersAction;
            const keyByAction = {
              pause: "p",
              restart: "r",
              exit: "Escape",
            };
            const key = keyByAction[action];

            if (!key || !invadersIsActive) {
              return;
            }

            document.dispatchEvent(
              new KeyboardEvent("keydown", {
                key,
                bubbles: true,
                cancelable: true,
              }),
            );
          });
        });

        if (snakeRoot) {
          const snakeStateObserver = new MutationObserver(syncSnakeState);

          snakeStateObserver.observe(snakeRoot, {
            attributes: true,
            attributeFilter: ["hidden"],
            characterData: true,
            childList: true,
            subtree: true,
          });
        }

        window.addEventListener("tiendu:snake-exit", (event) => {
          const detail = event.detail ?? {};
          restoreProfile(detail.score ?? 0, detail.highScore ?? 0);
        });

        if (invadersRoot) {
          const invadersStateObserver = new MutationObserver(syncInvadersState);

          invadersStateObserver.observe(invadersRoot, {
            attributes: true,
            attributeFilter: ["hidden"],
            characterData: true,
            childList: true,
            subtree: true,
          });
        }

        window.addEventListener("tiendu:invaders-exit", (event) => {
          const detail = event.detail ?? {};
          restoreInvadersProfile(
            detail.score ?? 0,
            detail.highScore ?? 0,
            detail.wave ?? 1,
          );
        });

        startTerminalOutput().catch(() => {
          wrapper.classList.remove("terminal-typing-enabled");

          if (output) {
            output.setAttribute("aria-busy", "false");
          }

          revealShell();
        });
      })();
    </script>
  </section>
</BaseLayout>

