---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="landing-wrapper" aria-labelledby="home-title">
    <script is:inline data-astro-rerun>
      document.currentScript?.parentElement?.classList.add(
        "terminal-typing-enabled",
      );
    </script>

    <div class="neon-greeting" aria-live="polite">
      <span class="neon-mark" aria-hidden="true">✦</span>
      <p id="greeting">Xin chào! Cảm ơn bạn đã ghé thăm!</p>
      <span class="neon-mark" aria-hidden="true">✦</span>
    </div>

    <div class="terminal-card">
      <div class="terminal-header" aria-hidden="true">
        <span>TIENDU@HOME / PROFILE</span>
        <span class="terminal-status">
          <span class="status-light"></span>
          ONLINE
        </span>
      </div>

      <div class="terminal-screen">
        <div class="terminal-content">
          <p class="command-line" aria-label="Terminal command: profile">
            <span class="typed-command">
              <span class="prompt">TIENDU@HOME</span>
              <span class="path">:~$</span>
              <span> PROFILE</span>
            </span>
            <span class="block-cursor" aria-hidden="true"></span>
          </p>

          <div class="output-stage">
            <div class="output-measure" aria-hidden="true">
              <p class="terminal-title">I'M TIEN.</p>

              <p>
                I work across Linux systems, cloud infrastructure, distributed
                workloads, monitoring, automation, and production reliability.
              </p>

              <p>
                This site is where I keep technical notes, engineering references,
                small projects, and lessons from systems that failed in interesting
                ways.
              </p>
            </div>

            <section class="output" aria-busy="false">
              <h1
                id="home-title"
                class="terminal-title"
                data-terminal-line
                data-speed="55"
              >
                I'M TIEN.
              </h1>

              <p data-terminal-line data-speed="24">
                I work across Linux systems, cloud infrastructure, distributed
                workloads, monitoring, automation, and production reliability.
              </p>

              <p data-terminal-line data-speed="24">
                This site is where I keep technical notes, engineering references,
                small projects, and lessons from systems that failed in interesting
                ways.
              </p>
            </section>
          </div>

          <p class="terminal-footer" data-terminal-footer aria-hidden="true">
            <span>READY</span>
            <span>SESSION 01</span>
          </p>
        </div>
      </div>
    </div>

    <script is:inline data-astro-rerun>
      (() => {
        const wrapper = document.currentScript?.closest(".landing-wrapper");

        if (!wrapper || wrapper.dataset.animationStarted === "true") {
          return;
        }

        wrapper.dataset.animationStarted = "true";

        const greetings = [
          "Hey there! Thanks for stopping by!",
          "Hallo! Danke, dass du vorbeischaust!",
          "Bonjour ! Merci de votre visite !",
          "¡Hola! ¡Gracias por visitar!",
          "Привет! Спасибо за визит!",
          "Selamat datang! Terima kasih telah berkunjung!",
          "안녕하세요! 방문해 주셔서 감사합니다!",
          "こんにちは！ご訪問ありがとうございます！",
          "你好！感谢你的到访！",
          "Xin chào! Cảm ơn bạn đã ghé thăm!",
        ];

        const greeting = wrapper.querySelector("#greeting");
        const output = wrapper.querySelector(".output");
        const commandCursor = wrapper.querySelector(".block-cursor");
        const footer = wrapper.querySelector("[data-terminal-footer]");
        const reducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        );

        const sleep = (milliseconds) =>
          new Promise((resolve) => window.setTimeout(resolve, milliseconds));

        const startGreeting = () => {
          if (!greeting || reducedMotion.matches) {
            return;
          }

          let index = greetings.indexOf(greeting.textContent?.trim() ?? "");

          window.setInterval(() => {
            greeting.classList.add("is-changing");

            window.setTimeout(() => {
              index = (index + 1) % greetings.length;
              greeting.textContent = greetings[index];
              greeting.classList.remove("is-changing");
            }, 160);
          }, 3000);
        };

        const typeLine = async (element, text) => {
          const speed = Number(element.dataset.speed ?? 24);

          element.style.visibility = "visible";
          element.classList.add("is-typing");

          for (const character of text) {
            element.textContent += character;

            if (
              character === "." ||
              character === "?" ||
              character === "!"
            ) {
              await sleep(speed * 5);
            } else if (
              character === "," ||
              character === ":" ||
              character === ";"
            ) {
              await sleep(speed * 2.5);
            } else {
              await sleep(speed);
            }
          }

          element.classList.remove("is-typing");
        };

        const startTerminalOutput = async () => {
          if (!output) {
            wrapper.classList.remove("terminal-typing-enabled");
            return;
          }

          const lines = Array.from(
            output.querySelectorAll("[data-terminal-line]"),
          );

          if (reducedMotion.matches) {
            wrapper.classList.remove("terminal-typing-enabled");
            output.setAttribute("aria-busy", "false");
            footer?.classList.add("terminal-footer-visible");
            return;
          }

          const textByLine = lines.map((line) =>
            (line.textContent ?? "").replace(/\s+/g, " ").trim(),
          );

          output.setAttribute("aria-busy", "true");

          lines.forEach((line) => {
            line.textContent = "";
            line.style.visibility = "hidden";
          });

          await sleep(1850);
          commandCursor?.classList.add("cursor-dimmed");

          for (let index = 0; index < lines.length; index += 1) {
            await typeLine(lines[index], textByLine[index]);
            await sleep(index === 0 ? 420 : 650);
          }

          footer?.classList.add("terminal-footer-visible");
          output.setAttribute("aria-busy", "false");
          wrapper.classList.remove("terminal-typing-enabled");
        };

        startGreeting();

        startTerminalOutput().catch(() => {
          wrapper.classList.remove("terminal-typing-enabled");

          if (output) {
            output.setAttribute("aria-busy", "false");
          }
        });
      })();
    </script>
  </section>
</BaseLayout>

<style>
  :root {
    --terminal-screen: #07120b;
    --terminal-screen-deep: #020704;
    --terminal-green: #c7f08b;
    --terminal-green-bright: #e7ffb0;
    --terminal-green-dim: #7fa45c;
    --terminal-glow: rgb(199 240 139 / 24%);
    --neon-warm: #d9805d;
    --neon-cool: #6f8c83;
  }

  .landing-wrapper {
    margin: 1.5rem auto 2.5rem;
    max-width: 760px;
  }

  .neon-greeting {
    align-items: center;
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin: 0 auto 1.2rem;
    min-height: 2.4rem;
    padding-inline: 0.75rem;
    text-align: center;
  }

  .neon-greeting p {
    color: var(--neon-warm);
    font-family: var(--font-ui);
    font-size: clamp(0.95rem, 2.5vw, 1.08rem);
    font-weight: 600;
    letter-spacing: 0.015em;
    line-height: 1.25;
    margin: 0;
    max-width: none;
    text-shadow:
      0 0 1px rgb(255 255 255 / 70%),
      0 0 5px rgb(217 128 93 / 34%),
      0 0 12px rgb(217 128 93 / 16%);
  }

  .neon-mark {
    color: var(--neon-cool);
    font-size: 0.72rem;
    opacity: 0.78;
    text-shadow: 0 0 6px rgb(111 140 131 / 36%);
  }

  .neon-greeting p.is-changing {
    animation: neon-flicker 160ms steps(2, end);
  }

  .terminal-card {
    border: 1px solid rgb(38 40 33 / 48%);
    border-radius: 4px;
    box-shadow:
      0 12px 32px rgb(55 48 37 / 10%),
      0 1px 0 rgb(255 255 255 / 58%);
    overflow: hidden;
  }

  .terminal-header {
    align-items: center;
    background: rgb(244 240 230 / 88%);
    border-bottom: 1px solid var(--line-dark);
    color: var(--muted);
    display: flex;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    justify-content: space-between;
    letter-spacing: 0.11em;
    padding: 0.62rem 0.85rem;
    text-transform: uppercase;
  }

  .terminal-status {
    align-items: center;
    display: inline-flex;
    gap: 0.42rem;
  }

  .status-light {
    background: var(--terminal-green);
    border-radius: 50%;
    box-shadow:
      0 0 4px rgb(199 240 139 / 70%),
      0 0 9px rgb(199 240 139 / 34%);
    height: 6px;
    width: 6px;
  }

  .terminal-screen {
    background:
      radial-gradient(
        circle at 48% 30%,
        rgb(41 79 44 / 17%) 0%,
        transparent 57%
      ),
      linear-gradient(
        180deg,
        var(--terminal-screen) 0%,
        var(--terminal-screen-deep) 100%
      );
    overflow: hidden;
    position: relative;
  }

  .terminal-screen::before {
    background:
      repeating-linear-gradient(
        to bottom,
        rgb(255 255 255 / 0%) 0,
        rgb(255 255 255 / 0%) 3px,
        rgb(0 0 0 / 11%) 4px
      );
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
    z-index: 2;
  }

  .terminal-content {
    color: var(--terminal-green);
    display: grid;
    font-family: var(--font-terminal);
    font-synthesis: none;
    gap: 1.3rem;
    letter-spacing: 0.035em;
    padding: clamp(1.35rem, 4vw, 2.1rem);
    position: relative;
    text-shadow:
      0 0 4px var(--terminal-glow),
      0 0 9px rgb(199 240 139 / 7%);
    z-index: 1;
  }

  .command-line {
    align-items: baseline;
    color: var(--terminal-green-dim);
    display: flex;
    font-size: 1.18rem;
    line-height: 1.2;
    margin: 0;
    max-width: none;
    white-space: nowrap;
  }

  .typed-command {
    animation: command-typing 1.7s steps(24, end) forwards;
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    width: 0;
  }

  .prompt {
    color: var(--terminal-green-bright);
  }

  .path {
    color: var(--terminal-green);
  }

  .block-cursor {
    animation: cursor-blink 0.85s steps(1, end) infinite;
    background: var(--terminal-green-bright);
    box-shadow: 0 0 6px var(--terminal-green);
    display: inline-block;
    flex: 0 0 auto;
    height: 0.9em;
    margin-left: 0.2rem;
    transform: translateY(0.1em);
    transition: opacity 160ms ease;
    width: 0.52em;
  }

  .block-cursor.cursor-dimmed {
    opacity: 0.22;
  }

  .output-stage {
    display: grid;
  }

  .output-measure,
  .output {
    grid-area: 1 / 1;
  }

  .output-measure {
    visibility: hidden;
  }

  .landing-wrapper.terminal-typing-enabled .output [data-terminal-line] {
    visibility: hidden;
  }

  .terminal-title {
    color: var(--terminal-green-bright);
    font-family: inherit;
    font-size: clamp(2rem, 6vw, 3rem);
    font-weight: 400;
    letter-spacing: 0.075em;
    line-height: 1;
    margin: 0 0 1.2rem;
    text-shadow:
      0 0 5px rgb(226 255 173 / 42%),
      0 0 13px rgb(199 240 139 / 15%);
  }

  .output p,
  .output-measure p {
    color: var(--terminal-green);
    font-size: 1.28rem;
    line-height: 1.42;
    margin: 0 0 1rem;
    max-width: 58ch;
  }

  .output .terminal-title,
  .output-measure .terminal-title {
    color: var(--terminal-green-bright);
    font-size: clamp(2rem, 6vw, 3rem);
    line-height: 1;
    margin-bottom: 1.2rem;
  }

  .output .is-typing::after {
    animation: cursor-blink 0.85s steps(1, end) infinite;
    background: var(--terminal-green-bright);
    box-shadow: 0 0 5px var(--terminal-green);
    content: "";
    display: inline-block;
    height: 0.76em;
    margin-left: 0.16rem;
    transform: translateY(0.08em);
    width: 0.44em;
  }

  .terminal-footer {
    align-items: center;
    border-top: 1px solid rgb(199 240 139 / 15%);
    color: var(--terminal-green-dim);
    display: flex;
    font-size: 0.92rem;
    justify-content: space-between;
    letter-spacing: 0.1em;
    margin: 0;
    max-width: none;
    opacity: 0;
    padding-top: 0.72rem;
    transition: opacity 220ms ease;
  }

  .terminal-footer-visible {
    opacity: 1;
  }

  @keyframes command-typing {
    from {
      width: 0;
    }

    to {
      width: 24ch;
    }
  }

  @keyframes cursor-blink {
    50% {
      opacity: 0;
    }
  }

  @keyframes neon-flicker {
    0%,
    100% {
      filter: brightness(1);
      opacity: 1;
    }

    35% {
      filter: brightness(0.55);
      opacity: 0.45;
    }

    65% {
      filter: brightness(1.28);
      opacity: 0.92;
    }
  }

  @media (min-width: 600px) {
    .landing-wrapper {
      margin-block: 2.25rem 3.5rem;
    }
  }

  @media (max-width: 520px) {
    .landing-wrapper {
      margin-top: 0.75rem;
    }

    .neon-greeting {
      gap: 0.5rem;
      margin-bottom: 0.9rem;
      min-height: 3rem;
      padding-inline: 0.25rem;
    }

    .neon-greeting p {
      font-size: 0.91rem;
    }

    .neon-mark {
      font-size: 0.6rem;
    }

    .terminal-header {
      font-size: 0.63rem;
      letter-spacing: 0.08em;
      padding: 0.52rem 0.65rem;
    }

    .terminal-content {
      gap: 1.05rem;
      padding: 1.05rem;
    }

    .command-line {
      font-size: 1.02rem;
      overflow: hidden;
    }

    .output p,
    .output-measure p {
      font-size: 1.13rem;
      line-height: 1.4;
    }

    .output .terminal-title,
    .output-measure .terminal-title {
      font-size: 2.05rem;
      letter-spacing: 0.055em;
    }

    .terminal-footer {
      font-size: 0.8rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .typed-command {
      animation: none;
      width: auto;
    }

    .block-cursor,
    .output .is-typing::after,
    .neon-greeting p.is-changing {
      animation: none;
    }

    .terminal-footer {
      opacity: 1;
      transition: none;
    }
  }
</style>
