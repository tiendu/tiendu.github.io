---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <main class="landing-wrapper" aria-labelledby="home-title">
    <p class="landing-kicker">
      Platform operations · reliability · automation
    </p>

    <div class="terminal-container">
      <div class="menu-bar" aria-hidden="true">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>

      <div class="typeme" aria-label="Terminal command: who am I">
        <span class="text-secondary">coffee@fridge</span>
        <span class="text-background"> ~ </span>
        <span class="cursor">$ </span>whoami
      </div>

      <section class="output">
        <h1 id="home-title">I'm Tien.</h1>

        <p>
          I work across Linux systems, cloud infrastructure, distributed
          workloads, monitoring, automation, and production reliability.
        </p>

        <p>
          This site is where I keep technical notes, engineering references,
          small projects, and lessons from systems that failed in interesting
          ways.
        </p>
      </section>
    </div>
  </main>
</BaseLayout>

<style>
  :root {
    --bg-terminal: #303446;
    --fg-primary: #c6d0f5;
    --fg-secondary: #8caaee;
    --fg-dim: #b5bfe2;
    --cursor: #f2d5cf;
  }

  .landing-wrapper {
    margin: 2rem 0 3rem;
    max-width: 700px;
  }

  .landing-kicker {
    color: var(--fg-secondary);
    font-size: 1.05rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    margin-bottom: 1rem;
  }

  .terminal-container {
    background: var(--bg-terminal);
    border: 1px solid rgb(0 0 0 / 60%);
    border-radius: 10px;
    box-shadow: 0 4px 10px rgb(0 0 0 / 18%);
    color: var(--fg-primary);
    overflow: hidden;
  }

  .menu-bar {
    align-items: center;
    background: #e0e0e0;
    display: flex;
    gap: 8px;
    padding: 0.65rem 1rem;
  }

  .dot {
    border-radius: 50%;
    height: 12px;
    width: 12px;
  }

  .dot.red {
    background: #ff5f57;
  }

  .dot.yellow {
    background: #ffbd2e;
  }

  .dot.green {
    background: #28c840;
  }

  .typeme,
  .output {
    margin-inline: 1rem;
  }

  .typeme {
    border-right: 10px solid var(--cursor);
    display: inline-block;
    font-family: var(--font-mono);
    margin-top: 1.15rem;
    max-width: calc(100% - 2rem);
    overflow: hidden;
    white-space: nowrap;
    animation:
      typing 1.8s steps(25),
      blink 0.55s step-end infinite alternate;
  }

  .text-secondary {
    color: var(--fg-secondary);
  }

  .text-background {
    color: var(--fg-dim);
  }

  .cursor {
    color: var(--cursor);
  }

  .output {
    color: var(--fg-primary);
    margin-bottom: 1.25rem;
    margin-top: 1.25rem;
    animation: fade 3.2s;
  }

  .output h1 {
    color: var(--fg-primary);
    font-size: clamp(1.7rem, 4vw, 2.25rem);
    margin: 0 0 0.9rem;
  }

  .output p {
    margin: 0 0 0.9rem;
    max-width: 62ch;
  }

  @keyframes typing {
    from {
      width: 0;
    }

    to {
      width: 25ch;
    }
  }

  @keyframes blink {
    50% {
      border-color: transparent;
    }
  }

  @keyframes fade {
    0%,
    42% {
      opacity: 0;
      transform: translateY(4px);
    }

    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 600px) {
    .landing-wrapper {
      font-size: 1.05rem;
      margin: 3rem auto 4rem;
    }

    .typeme,
    .output {
      margin-inline: 1.5rem;
    }

    .typeme {
      margin-top: 1.4rem;
      max-width: calc(100% - 3rem);
    }

    .output {
      margin-bottom: 1.5rem;
    }
  }

  @media (max-width: 420px) {
    .landing-wrapper {
      margin-top: 1rem;
    }

    .landing-kicker {
      font-size: 0.95rem;
    }

    .typeme {
      border-right-width: 7px;
      font-size: 0.8rem;
    }

    .terminal-links {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.45rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .typeme,
    .output {
      animation: none;
    }

    .typeme {
      border-right: 0;
    }
  }
</style>
