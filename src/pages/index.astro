---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="landing-wrapper" aria-labelledby="home-title">
    <script is:inline data-astro-rerun>
      document.currentScript?.parentElement?.classList.add(
        "terminal-typing-enabled",
      );
    </script>

    <div class="neon-sign" aria-live="polite">
      <span class="neon-bolt left" aria-hidden="true"></span>
      <p id="greeting">Xin chào! Cảm ơn bạn đã ghé thăm!</p>
      <span class="neon-bolt right" aria-hidden="true"></span>
    </div>

    <div class="terminal-shell">
      <div class="terminal-panel" aria-hidden="true">
        <span class="terminal-model">SYSTEM CONSOLE</span>

        <span class="terminal-status">
          <span class="status-light"></span>
          ONLINE
        </span>
      </div>

      <div class="terminal-screen">
        <div class="terminal-content">
          <p class="command-line" aria-label="Terminal command: profile">
            <span class="typed-command">
              <span class="prompt">TIENDU@HOME</span>
              <span class="path">:~$</span>
              <span> PROFILE</span>
            </span>
            <span class="block-cursor" aria-hidden="true"></span>
          </p>

          <section class="output" aria-busy="false">
            <h1 id="home-title" data-terminal-line data-speed="55">
              I'M TIEN.
            </h1>

            <p data-terminal-line data-speed="24">
              I work across Linux systems, cloud infrastructure, distributed
              workloads, monitoring, automation, and production reliability.
            </p>

            <p data-terminal-line data-speed="24">
              This site is where I keep technical notes, engineering references,
              small projects, and lessons from systems that failed in interesting
              ways.
            </p>
          </section>

          <p class="terminal-footer" data-terminal-footer aria-hidden="true">
            READY
            <span>SESSION 01</span>
          </p>
        </div>
      </div>
    </div>

    <script is:inline data-astro-rerun>
      (() => {
        const wrapper = document.currentScript?.closest(".landing-wrapper");

        if (!wrapper || wrapper.dataset.animationStarted === "true") {
          return;
        }

        wrapper.dataset.animationStarted = "true";

        const greetings = [
          "Hey there! Thanks for stopping by!",
          "Hallo! Danke, dass du vorbeischaust!",
          "Bonjour ! Merci de votre visite !",
          "¡Hola! ¡Gracias por visitar!",
          "Привет! Спасибо за визит!",
          "Selamat datang! Terima kasih telah berkunjung!",
          "안녕하세요! 방문해 주셔서 감사합니다!",
          "こんにちは！ご訪問ありがとうございます！",
          "你好！感谢你的到访！",
          "Xin chào! Cảm ơn bạn đã ghé thăm!",
        ];

        const greeting = wrapper.querySelector("#greeting");
        const output = wrapper.querySelector(".output");
        const footer = wrapper.querySelector("[data-terminal-footer]");
        const reducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        );

        const sleep = (milliseconds) =>
          new Promise((resolve) => window.setTimeout(resolve, milliseconds));

        const startGreeting = () => {
          if (!greeting || reducedMotion.matches) {
            return;
          }

          let index = greetings.indexOf(greeting.textContent?.trim() ?? "");

          window.setInterval(() => {
            greeting.classList.add("is-changing");

            window.setTimeout(() => {
              index = (index + 1) % greetings.length;
              greeting.textContent = greetings[index];
              greeting.classList.remove("is-changing");
            }, 190);
          }, 3000);
        };

        const typeLine = async (element, text) => {
          const speed = Number(element.dataset.speed ?? 24);

          element.style.visibility = "visible";
          element.classList.add("is-typing");

          for (const character of text) {
            element.textContent += character;

            if (
              character === "." ||
              character === "?" ||
              character === "!"
            ) {
              await sleep(speed * 5);
            } else if (
              character === "," ||
              character === ":" ||
              character === ";"
            ) {
              await sleep(speed * 2.5);
            } else {
              await sleep(speed);
            }
          }

          element.classList.remove("is-typing");
        };

        const startTerminalOutput = async () => {
          if (!output) {
            wrapper.classList.remove("terminal-typing-enabled");
            return;
          }

          const lines = Array.from(
            output.querySelectorAll("[data-terminal-line]"),
          );

          if (reducedMotion.matches) {
            wrapper.classList.remove("terminal-typing-enabled");
            output.setAttribute("aria-busy", "false");
            return;
          }

          const textByLine = lines.map((line) =>
            (line.textContent ?? "").replace(/\s+/g, " ").trim(),
          );

          output.setAttribute("aria-busy", "true");

          lines.forEach((line) => {
            line.textContent = "";
            line.style.visibility = "hidden";
          });

          if (footer) {
            footer.style.visibility = "hidden";
          }

          await sleep(1850);

          for (let index = 0; index < lines.length; index += 1) {
            await typeLine(lines[index], textByLine[index]);
            await sleep(index === 0 ? 420 : 650);
          }

          if (footer) {
            footer.style.visibility = "visible";
            footer.classList.add("terminal-footer-visible");
          }

          output.setAttribute("aria-busy", "false");
          wrapper.classList.remove("terminal-typing-enabled");
        };

        startGreeting();

        startTerminalOutput().catch(() => {
          wrapper.classList.remove("terminal-typing-enabled");

          if (output) {
            output.setAttribute("aria-busy", "false");
          }
        });
      })();
    </script>
  </section>
</BaseLayout>

<style>
  @import url("https://fonts.googleapis.com/css2?family=VT323&display=swap");

  :root {
    --terminal-shell-top: #5a605b;
    --terminal-shell-bottom: #343936;
    --terminal-border: #242825;
    --terminal-screen: #07120b;
    --terminal-screen-deep: #020704;
    --terminal-green: #c7f08b;
    --terminal-green-bright: #e7ffb0;
    --terminal-green-dim: #7fa45c;
    --terminal-glow: rgb(199 240 139 / 24%);
    --neon-pink: #ff4fd8;
    --neon-cyan: #53e7ff;
    --neon-warm: #ffe67a;
  }

  .landing-wrapper {
    margin: 2rem 0 3rem;
    max-width: 760px;
  }

  .neon-sign {
    align-items: center;
    background:
      linear-gradient(
        180deg,
        rgb(20 18 29 / 96%) 0%,
        rgb(10 10 17 / 98%) 100%
      );
    border: 1px solid rgb(83 231 255 / 42%);
    border-radius: 7px;
    box-shadow:
      inset 0 0 14px rgb(83 231 255 / 7%),
      0 0 8px rgb(83 231 255 / 14%),
      0 0 18px rgb(255 79 216 / 10%);
    display: grid;
    gap: 0.7rem;
    grid-template-columns: 16px minmax(0, 1fr) 16px;
    height: 62px;
    margin: 0 auto 0.95rem;
    max-width: 590px;
    padding: 0.45rem 0.9rem;
    position: relative;
    width: 78%;
  }

  .neon-sign::before,
  .neon-sign::after {
    background: #35353c;
    content: "";
    height: 8px;
    position: absolute;
    top: -8px;
    width: 2px;
  }

  .neon-sign::before {
    left: 16%;
  }

  .neon-sign::after {
    right: 16%;
  }

  .neon-sign p {
    align-items: center;
    color: var(--neon-warm);
    display: flex;
    font-family:
      var(--font-body),
      "Noto Sans",
      system-ui,
      sans-serif;
    font-size: clamp(0.95rem, 2.4vw, 1.15rem);
    font-weight: 600;
    height: 100%;
    justify-content: center;
    letter-spacing: 0.015em;
    line-height: 1.15;
    margin: 0;
    max-width: none;
    text-align: center;
    text-shadow:
      0 0 2px #fff4b0,
      0 0 6px var(--neon-warm),
      0 0 12px rgb(255 79 216 / 65%),
      0 0 22px rgb(255 79 216 / 32%);
  }

  .neon-sign p.is-changing {
    animation: neon-flicker 190ms steps(2, end);
  }

  .neon-bolt {
    background: var(--neon-cyan);
    border-radius: 999px;
    box-shadow:
      0 0 4px var(--neon-cyan),
      0 0 10px rgb(83 231 255 / 72%),
      0 0 16px rgb(83 231 255 / 30%);
    display: block;
    height: 4px;
  }

  .neon-bolt.left {
    transform: rotate(-10deg);
  }

  .neon-bolt.right {
    transform: rotate(10deg);
  }

  .terminal-shell {
    background:
      linear-gradient(
        180deg,
        var(--terminal-shell-top) 0%,
        #484e49 48%,
        var(--terminal-shell-bottom) 100%
      );
    border: 1px solid var(--terminal-border);
    border-radius: 8px;
    box-shadow:
      inset 0 1px 0 rgb(255 255 255 / 18%),
      inset 0 -3px 5px rgb(0 0 0 / 30%),
      0 8px 24px rgb(0 0 0 / 20%);
    padding: 10px;
  }

  .terminal-panel {
    align-items: center;
    color: rgb(255 255 255 / 62%);
    display: flex;
    font-family: "VT323", monospace;
    font-size: 1rem;
    justify-content: space-between;
    letter-spacing: 0.09em;
    padding: 0.05rem 0.35rem 0.55rem;
    text-shadow: 0 1px 1px rgb(0 0 0 / 65%);
  }

  .terminal-model {
    font-weight: 400;
  }

  .terminal-status {
    align-items: center;
    display: inline-flex;
    gap: 0.45rem;
  }

  .status-light {
    background: var(--terminal-green);
    border: 1px solid #27351d;
    border-radius: 50%;
    box-shadow:
      0 0 5px var(--terminal-green),
      0 0 12px rgb(199 240 139 / 42%);
    display: inline-block;
    height: 7px;
    width: 7px;
  }

  .terminal-screen {
    background:
      radial-gradient(
        circle at 50% 38%,
        rgb(41 79 44 / 25%) 0%,
        transparent 58%
      ),
      linear-gradient(
        180deg,
        var(--terminal-screen) 0%,
        var(--terminal-screen-deep) 100%
      );
    border: 2px solid #171b18;
    border-radius: 4px;
    box-shadow:
      inset 0 0 0 1px rgb(255 255 255 / 4%),
      inset 0 0 28px rgb(0 0 0 / 90%),
      inset 0 0 44px rgb(73 125 70 / 11%);
    min-height: 610px;
    overflow: hidden;
    position: relative;
  }

  .terminal-screen::before {
    background:
      repeating-linear-gradient(
        to bottom,
        rgb(255 255 255 / 0%) 0,
        rgb(255 255 255 / 0%) 3px,
        rgb(0 0 0 / 16%) 4px
      );
    content: "";
    inset: 0;
    pointer-events: none;
    position: absolute;
    z-index: 2;
  }

  .terminal-screen::after {
    background:
      linear-gradient(
        90deg,
        rgb(255 0 0 / 1.2%),
        rgb(0 255 0 / 0.8%),
        rgb(0 0 255 / 1.2%)
      );
    content: "";
    inset: 0;
    mix-blend-mode: screen;
    opacity: 0.35;
    pointer-events: none;
    position: absolute;
    z-index: 3;
  }

  .terminal-content {
    color: var(--terminal-green);
    display: grid;
    font-family: "VT323", monospace;
    font-synthesis: none;
    gap: 1.65rem;
    grid-template-rows: auto minmax(0, 1fr) auto;
    letter-spacing: 0.035em;
    min-height: 570px;
    padding: clamp(1.15rem, 4vw, 2rem);
    position: relative;
    text-shadow:
      0 0 4px var(--terminal-glow),
      0 0 10px rgb(199 240 139 / 9%);
    z-index: 1;
  }

  .command-line {
    align-items: baseline;
    color: var(--terminal-green-dim);
    display: flex;
    font-size: 1.25rem;
    line-height: 1.2;
    margin: 0;
    max-width: none;
    white-space: nowrap;
  }

  .typed-command {
    animation: command-typing 1.7s steps(24, end) forwards;
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    width: 0;
  }

  .prompt {
    color: var(--terminal-green-bright);
  }

  .path {
    color: var(--terminal-green);
  }

  .block-cursor {
    animation: cursor-blink 0.85s steps(1, end) infinite;
    background: var(--terminal-green-bright);
    box-shadow: 0 0 7px var(--terminal-green);
    display: inline-block;
    flex: 0 0 auto;
    height: 0.95em;
    margin-left: 0.2rem;
    transform: translateY(0.12em);
    width: 0.58em;
  }

  .landing-wrapper.terminal-typing-enabled .output [data-terminal-line],
  .landing-wrapper.terminal-typing-enabled [data-terminal-footer] {
    visibility: hidden;
  }

  .output {
    align-self: start;
    min-height: 390px;
  }

  .output h1 {
    color: var(--terminal-green-bright);
    font-family: inherit;
    font-size: clamp(2.1rem, 6vw, 3.25rem);
    font-weight: 400;
    letter-spacing: 0.08em;
    line-height: 1;
    margin: 0 0 1.3rem;
    text-shadow:
      0 0 5px rgb(226 255 173 / 46%),
      0 0 14px rgb(199 240 139 / 18%);
  }

  .output p {
    color: var(--terminal-green);
    font-size: 1.35rem;
    line-height: 1.4;
    margin: 0 0 1.1rem;
    max-width: 58ch;
  }

  .output .is-typing::after {
    animation: cursor-blink 0.85s steps(1, end) infinite;
    background: var(--terminal-green-bright);
    box-shadow: 0 0 6px var(--terminal-green);
    content: "";
    display: inline-block;
    height: 0.8em;
    margin-left: 0.18rem;
    transform: translateY(0.08em);
    width: 0.48em;
  }

  .terminal-footer {
    align-items: center;
    align-self: end;
    border-top: 1px solid rgb(199 240 139 / 20%);
    color: var(--terminal-green-dim);
    display: flex;
    font-size: 1rem;
    justify-content: space-between;
    letter-spacing: 0.1em;
    margin: 0;
    max-width: none;
    min-height: 34px;
    opacity: 0;
    padding-top: 0.65rem;
    transition: opacity 260ms ease;
  }

  .terminal-footer-visible {
    opacity: 1;
  }

  @keyframes command-typing {
    from {
      width: 0;
    }

    to {
      width: 24ch;
    }
  }

  @keyframes cursor-blink {
    50% {
      opacity: 0;
    }
  }

  @keyframes neon-flicker {
    0%,
    100% {
      filter: brightness(1);
      opacity: 1;
    }

    30% {
      filter: brightness(0.45);
      opacity: 0.35;
    }

    55% {
      filter: brightness(1.5);
      opacity: 0.9;
    }

    75% {
      filter: brightness(0.7);
      opacity: 0.5;
    }
  }

  @media (min-width: 600px) {
    .landing-wrapper {
      margin: 3rem auto 4rem;
    }
  }

  @media (max-width: 520px) {
    .landing-wrapper {
      margin-top: 1rem;
    }

    .neon-sign {
      gap: 0.45rem;
      grid-template-columns: 10px minmax(0, 1fr) 10px;
      height: 74px;
      padding: 0.5rem 0.65rem;
      width: 86%;
    }

    .neon-sign p {
      font-size: 0.92rem;
    }

    .terminal-shell {
      border-radius: 7px;
      padding: 8px;
    }

    .terminal-panel {
      font-size: 0.9rem;
      padding-bottom: 0.45rem;
    }

    .terminal-screen {
      min-height: 610px;
    }

    .terminal-content {
      gap: 1.35rem;
      min-height: 570px;
      padding: 1.05rem;
    }

    .command-line {
      font-size: 1.05rem;
      overflow: hidden;
    }

    .output {
      min-height: 410px;
    }

    .output h1 {
      font-size: 2.15rem;
      letter-spacing: 0.06em;
    }

    .output p {
      font-size: 1.18rem;
      line-height: 1.42;
    }

    .terminal-footer {
      font-size: 0.9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .typed-command {
      animation: none;
      width: auto;
    }

    .block-cursor,
    .output .is-typing::after,
    .neon-sign p.is-changing {
      animation: none;
    }

    .terminal-footer {
      opacity: 1;
      transition: none;
    }
  }
</style>
