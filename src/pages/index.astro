---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout>
  <div class="landing-wrapper">
    <div class="landing-greeting" id="greeting">
      Xin chào! Cảm ơn bạn đã ghé thăm!
    </div>

    <div class="terminal-container">
      <div class="menu-bar" aria-hidden="true">
        <span class="dot red"></span>
        <span class="dot yellow"></span>
        <span class="dot green"></span>
      </div>

      <div class="typeme" aria-label="coffee at fridge, home directory, command: me help">
        <span class="text-secondary">coffee@fridge</span>
        <span class="text-background"> ~ </span>
        <span class="cursor">$ </span>me -h
      </div>

      <section class="output">
        <p>I'm Tien, a Platform Operations Engineer working across Linux, cloud infrastructure, distributed systems, monitoring, and production reliability.</p>
        <p>I troubleshoot complex failures, build automation and observability tools, and improve systems that need to run reliably at scale.</p>
        <p>Open to platform operations, cloud operations, production support, systems engineering, and scientific infrastructure opportunities.</p>
      </section>
    </div>
  </div>
</BaseLayout>

<script>
  const greetings = [
    "Hey there! Thanks for stopping by!",
    "Hallo! Danke, dass du vorbeischaust!",
    "Bonjour ! Merci de votre visite !",
    "¡Hola! ¡Gracias por visitar!",
    "Привет! Спасибо за визит!",
    "Selamat datang! Terima kasih telah berkunjung!",
    "안녕하세요! 방문해 주셔서 감사합니다!",
    "こんにちは！ご訪問ありがとうございます！",
    "你好！感谢你的到访！",
    "Xin chào! Cảm ơn bạn đã ghé thăm!",
  ];

  const greeting = document.querySelector<HTMLElement>("#greeting");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  if (greeting && !reducedMotion.matches) {
    let index = greetings.indexOf(greeting.textContent?.trim() ?? "");
    window.setInterval(() => {
      index = (index + 1) % greetings.length;
      greeting.textContent = greetings[index];
    }, 3000);
  }
</script>

<style>
  :root {
    --bg-terminal: #303446;
    --fg-primary: #c6d0f5;
    --fg-secondary: #8caaee;
    --fg-dim: #b5bfe2;
    --cursor: #f2d5cf;
  }

  .landing-wrapper {
    max-width: 700px;
    margin: 2rem 0 3rem;
  }

  .landing-greeting {
    color: var(--fg-secondary);
    font-weight: 500;
    font-size: 1.2rem;
    margin-bottom: 1rem;
  }

  .terminal-container {
    background: var(--bg-terminal);
    color: var(--fg-primary);
    padding: 1rem;
    border-radius: 10px;
    box-shadow: 0 4px 6px rgb(0 0 0 / 20%);
    border: 1px solid rgb(0 0 0 / 60%);
  }

  .menu-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: -1rem -1rem 1rem;
    padding: 0.5rem 1rem;
    background: #e0e0e0;
    border-radius: 10px 10px 0 0;
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }

  .dot.red { background: #ff5f57; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green { background: #28c840; }

  .typeme {
    display: inline-block;
    max-width: 100%;
    font-family: var(--font-mono);
    white-space: nowrap;
    overflow: hidden;
    border-right: 10px solid var(--cursor);
    animation: typing 2s steps(24), blink 0.5s step-end infinite alternate;
  }

  .text-secondary { color: var(--fg-secondary); }
  .text-background { color: var(--fg-dim); }
  .cursor { color: var(--cursor); }

  .output {
    margin-top: 1rem;
    color: var(--fg-primary);
    animation: fade 5s;
  }

  .output p {
    max-width: 80ch;
    margin: 0 0 0.8rem;
  }

  @keyframes typing {
    from { width: 0; }
    to { width: 24ch; }
  }

  @keyframes blink {
    50% { border-color: transparent; }
  }

  @keyframes fade {
    0%, 50% { opacity: 0; }
    100% { opacity: 1; }
  }

  @media (min-width: 600px) {
    .landing-wrapper {
      margin: 3rem auto 4rem;
      font-size: 1.05rem;
    }
  }

  @media (max-width: 420px) {
    .typeme {
      font-size: 0.83rem;
      border-right-width: 7px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .typeme,
    .output {
      animation: none;
    }

    .typeme {
      border-right: 0;
    }
  }
</style>
