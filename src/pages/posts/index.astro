---
import { getCollection } from "astro:content";
import SystemPageLayout from "../../layouts/SystemPageLayout.astro";
import {
  formatCompactDate,
  getPostRoute,
  readingTime,
  sortPosts,
} from "../../utils/posts";

const posts = sortPosts(
  await getCollection("blog", ({ data }) => !data.draft),
);
const pinned = posts.filter(({ data }) => data.pinned);
const normalPosts = posts.filter(({ data }) => !data.pinned);

const labelLine = (post: (typeof posts)[number]) => post.data.topic;
---

<SystemPageLayout
  title="Posts"
  moduleCode="LOG-ARCHIVE"
  description="Field notes, engineering references, and lessons from systems that failed."
  counter={`${posts.length} RECORDS`}
>
  {
    pinned.length > 0 && (
      <section class="archive-section priority" aria-labelledby="priority-title">
        <header class="archive-section-header">
          <div>
            <p class="system-section-code">PRIORITY / PINNED</p>
            <h2 id="priority-title">Pinned notes</h2>
          </div>
          <span>{pinned.length} RECORDS</span>
        </header>

        <div class="log-table-head" aria-hidden="true">
          <span>PIN</span>
          <span>DATE</span>
          <span>SUBJECT</span>
          <span>TOPIC / RUNTIME</span>
        </div>

        <ol class="log-list">
          {pinned.map((post, index) => (
            <li class="log-entry">
              <span class="log-number">P{String(index + 1).padStart(2, "0")}</span>
              <time class="log-date" datetime={post.data.date.toISOString()}>
                {formatCompactDate(post.data.date)}
              </time>
              <div class="log-main">
                <h3><a href={getPostRoute(post)}>{post.data.title}</a></h3>
              </div>
              <p class="log-subline">
                {labelLine(post)}<br />
                <span>{readingTime(post.body ?? "")} MIN READ</span>
              </p>
            </li>
          ))}
        </ol>
      </section>
    )
  }

  <section class="archive-section" aria-labelledby="all-records-title">
    <header class="archive-section-header">
      <div>
        <p class="system-section-code">STORAGE / COMPLETE</p>
        <h2 id="all-records-title">Complete archive</h2>
      </div>
      <span>{normalPosts.length} RECORDS</span>
    </header>

    {
      normalPosts.length > 0 ? (
        <>
          <div class="log-table-head" aria-hidden="true">
            <span>ID</span>
            <span>DATE</span>
            <span>SUBJECT</span>
            <span>TOPIC / RUNTIME</span>
          </div>

          <ol class="log-list">
            {normalPosts.map((post, index) => (
              <li class="log-entry">
                <span class="log-number">{String(index + 1).padStart(3, "0")}</span>
                <time class="log-date" datetime={post.data.date.toISOString()}>
                  {formatCompactDate(post.data.date)}
                </time>
                <div class="log-main">
                  <h3><a href={getPostRoute(post)}>{post.data.title}</a></h3>
                </div>
                <p class="log-subline">
                  {labelLine(post)}<br />
                  <span>{readingTime(post.body ?? "")} MIN READ</span>
                </p>
              </li>
            ))}
          </ol>
        </>
      ) : (
        <p class="system-empty-state">NO RECORDS FOUND.</p>
      )
    }
  </section>
</SystemPageLayout>
