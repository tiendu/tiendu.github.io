---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import { getPostLabels, getPostRoute, sortPosts } from "../../utils/posts";

const posts = sortPosts(await getCollection("blog", ({ data }) => !data.draft));
const grouped = new Map<string, typeof posts>();

for (const post of posts) {
  for (const label of getPostLabels(post)) {
    const existing = grouped.get(label) ?? [];
    existing.push(post);
    grouped.set(label, existing);
  }
}

const groups = [...grouped.entries()].sort(([a], [b]) => a.localeCompare(b));
const slugify = (value: string) =>
  value.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");

const compactDate = (date: Date) =>
  new Intl.DateTimeFormat("en-CA", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
    timeZone: "UTC",
  }).format(date).replaceAll("-", ".");
---

<PageLayout
  title="Tags"
  fileCode="SUBJECT-INDEX"
  description="Browse the archive by topic, system, tool, or recurring engineering problem."
>
  {
    groups.length > 0 ? (
      <div class="tag-index">
        {groups.map(([label, taggedPosts]) => (
          <section class="tag-drawer" id={slugify(label)}>
            <header class="tag-drawer-header">
              <h2>{label}</h2>
              <span class="tag-count">{taggedPosts.length} FILES</span>
            </header>

            <ol class="tag-drawer-list">
              {taggedPosts.map((post) => (
                <li>
                  <time datetime={post.data.date.toISOString()}>
                    {compactDate(post.data.date)}
                  </time>
                  <a href={getPostRoute(post)}>{post.data.title}</a>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    ) : (
      <p>No tags yet.</p>
    )
  }
</PageLayout>
