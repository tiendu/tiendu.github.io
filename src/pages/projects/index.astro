---
import { PROJECTS } from "../../data/projects";
import SystemPageLayout from "../../layouts/SystemPageLayout.astro";
---

<SystemPageLayout
  title="Projects"
  moduleCode="PROGRAM-REGISTRY"
  description="Small tools built to solve real problems."
  counter={`${PROJECTS.length} PROGRAMS`}
>
  <div class="registry-head" aria-hidden="true">
    <span>ID</span>
    <span>PROGRAM</span>
    <span>INTERFACE</span>
  </div>

  <ol class="project-catalogue">
    {
      PROJECTS.map((project, index) => (
        <li class:list={["project-entry", { featured: project.featured }]}>
          <div class="project-index" aria-hidden="true">
            {String(index + 1).padStart(2, "0")}
          </div>

          <article class="project-main">
            <header class="project-header">
              <div>
                <p class="project-kicker">{project.label}</p>
                <h2>{project.name}</h2>
              </div>

              <span class:list={["project-state", { featured: project.featured }]}>
                {project.featured ? "FEATURED" : "SOURCE AVAILABLE"}
              </span>
            </header>

            <p class="project-summary">{project.summary}</p>
            <p class="project-details">{project.details}</p>

            <div class="project-runtime">
              <span>RUNTIME</span>
              <p>{project.tech}</p>
            </div>
          </article>

          <div class="project-actions">
            <a href={project.repo} target="_blank" rel="noopener noreferrer">
              OPEN SOURCE
            </a>
            <span>GITHUB / PUBLIC</span>
          </div>
        </li>
      ))
    }
  </ol>
</SystemPageLayout>
