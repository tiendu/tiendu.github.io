---
import "../../styles/components/arcade.css";
import "../../styles/components/invaders-game.css";
---

<section
  class="arcade-panel invaders-panel"
  data-invaders-game
  aria-label="Space Invaders game"
  hidden
>
  <div class="arcade-scoreboard invaders-scoreboard" aria-live="polite">
    <span>SCORE <output data-invaders-score>0000</output></span>
    <span>HIGH <output data-invaders-high-score>0000</output></span>
    <span>WAVE <output data-invaders-wave>01</output></span>
    <span>LIVES <output data-invaders-lives>3</output></span>
  </div>

  <div class="arcade-board-frame invaders-board-frame">
    <canvas
      class="arcade-board invaders-board"
      data-invaders-canvas
      width="480"
      height="560"
      tabindex="0"
      aria-label="Space Invaders game board. Use left and right arrows or A and D to move. Press Space to fire."
    ></canvas>

    <div class="arcade-overlay invaders-overlay" data-invaders-overlay>
      <strong data-invaders-state>PRESS FIRE OR MOVE</strong>
      <span data-invaders-message>ARROWS / A D / SPACE / SWIPE</span>
    </div>
  </div>

  <div class="arcade-pad invaders-pad" aria-label="Space Invaders controls">
    <button type="button" data-invaders-control="left" aria-label="Move left">◀</button>
    <button type="button" data-invaders-control="fire" aria-label="Fire">FIRE</button>
    <button type="button" data-invaders-control="right" aria-label="Move right">▶</button>
  </div>

  <p class="arcade-help invaders-help">
    ← → / A D MOVE · SPACE FIRE · P PAUSE · R RESTART · ESC EXIT
  </p>
</section>

<script>
  import { mountInvadersGames } from "../../scripts/games/invaders";

  mountInvadersGames();
</script>
