---
import "../../styles/components/arcade.css";
import "../../styles/components/breakout-game.css";
---

<section
  class="arcade-panel breakout-panel"
  data-breakout-game
  aria-label="Breakout game"
  hidden
>
  <div class="arcade-scoreboard breakout-scoreboard" aria-live="polite">
    <span>SCORE <output data-breakout-score>0000</output></span>
    <span>HIGH <output data-breakout-high-score>0000</output></span>
    <span>LEVEL <output data-breakout-level>01</output></span>
    <span>LIVES <output data-breakout-lives>3</output></span>
    <span>BALLS <output data-breakout-balls>1</output></span>
  </div>

  <div class="arcade-board-frame breakout-board-frame">
    <canvas
      class="arcade-board breakout-board"
      data-breakout-canvas
      width="480"
      height="560"
      tabindex="0"
      aria-label="Breakout game board. Use left and right arrows or A and D to move the paddle. Press Space to launch the ball."
    ></canvas>

    <div class="arcade-overlay breakout-overlay" data-breakout-overlay>
      <strong data-breakout-state>PRESS FIRE OR MOVE</strong>
      <span data-breakout-message>ARROWS / A D / SPACE / DRAG</span>
    </div>
  </div>

  <div class="arcade-pad breakout-pad" aria-label="Breakout controls">
    <button type="button" data-breakout-control="left" aria-label="Move left">◀</button>
    <button type="button" data-breakout-control="launch" aria-label="Launch ball">LAUNCH</button>
    <button type="button" data-breakout-control="right" aria-label="Move right">▶</button>
  </div>

  <p class="arcade-help breakout-help">
    ← → / A D MOVE · SPACE LAUNCH · P PAUSE · R RESTART · ESC EXIT
  </p>
</section>

<script>
  import { mountBreakoutGames } from "../../scripts/games/breakout";

  mountBreakoutGames();
</script>
