---
import "../../styles/components/arcade.css";
import "../../styles/components/snake-game.css";
---

<section
  class="arcade-panel snake-panel"
  data-snake-game
  aria-label="Neon Snake game"
  hidden
>
  <div class="arcade-scoreboard snake-scoreboard">
    <span>SCORE <output data-snake-score>00000</output></span>
    <span>FLOW <output data-snake-flow>x1</output></span>
    <span>SECTOR <output data-snake-mode>01</output></span>
    <span>HIGH <output data-snake-high-score>00000</output></span>
    <span
      class="snake-bonus-indicator"
      data-snake-bonus-indicator
      aria-label="Surge core time remaining"
      hidden
    >
      SURGE <output data-snake-bonus-time>5</output>
    </span>
    <span class="snake-overdrive-indicator">
      DRIVE <output data-snake-overdrive>······</output>
    </span>
  </div>

  <div class="arcade-board-frame snake-board-frame">
    <canvas
      class="arcade-board snake-board"
      data-snake-canvas
      width="440"
      height="480"
      tabindex="0"
      aria-label="Neon Snake top-down arena. Guide the transparent block snake with the arrow keys or W A S D, and hold Space for overdrive."
    >
      Snake requires a browser with canvas support.
    </canvas>

    <div class="arcade-overlay snake-overlay" data-snake-overlay>
      <strong data-snake-state>NEON RUN</strong>
      <span data-snake-message>STEER · BUILD FLOW · BURN THE TAIL</span>

      <div
        class="arcade-resume-picker"
        data-snake-resume-picker
        role="group"
        aria-label="Resume saved Neon Snake game"
        hidden
      >
        <button type="button" data-snake-resume="continue">
          CONTINUE
          <small data-snake-resume-summary>SAVED RUN</small>
        </button>
        <button type="button" data-snake-resume="new">
          NEW RUN
          <small>DISCARD SAVE</small>
        </button>
      </div>

      <div class="snake-start-picker" data-snake-start-picker>
        <button type="button" data-snake-start>
          START RUN
          <small>ARROWS / WASD · SPACE DRIVE</small>
        </button>
      </div>

      <div
        class="snake-protocol-picker"
        data-snake-protocol-picker
        role="group"
        aria-label="Choose the next sector protocol"
        hidden
      >
        <button type="button" data-snake-protocol="left">
          <strong data-snake-protocol-name="left">OVERCLOCK</strong>
          <small data-snake-protocol-summary="left">REMOVE 2 TAIL · SPEED -5%</small>
        </button>
        <button type="button" data-snake-protocol="right">
          <strong data-snake-protocol-name="right">DENSE GRID</strong>
          <small data-snake-protocol-summary="right">SCORE +35% · SPEED +6%</small>
        </button>
      </div>
    </div>
  </div>

  <div class="arcade-pad snake-pad" aria-label="Neon Snake controls">
    <button
      type="button"
      class="snake-direction-up"
      data-snake-direction="up"
      aria-label="Move up"
    >
      ↑
    </button>
    <button
      type="button"
      class="snake-direction-left"
      data-snake-direction="left"
      aria-label="Move left"
    >
      ←
    </button>
    <button
      type="button"
      class="snake-overdrive-button"
      data-snake-overdrive-button
      aria-label="Hold for overdrive"
    >
      DRIVE
    </button>
    <button
      type="button"
      class="snake-direction-right"
      data-snake-direction="right"
      aria-label="Move right"
    >
      →
    </button>
    <button
      type="button"
      class="snake-direction-down"
      data-snake-direction="down"
      aria-label="Move down"
    >
      ↓
    </button>
  </div>

  <p class="arcade-help snake-help">
    ARROWS / WASD STEER · HOLD SPACE OVERDRIVE · P PAUSE · R RETRY · ESC EXIT
  </p>

  <p
    class="sr-only"
    data-snake-status
    aria-live="polite"
    aria-atomic="true"
  ></p>
</section>
