---
import type { MarkdownHeading } from "astro";
import { getCollection } from "astro:content";
import BackToTop from "../components/BackToTop.astro";
import SystemHeader from "../components/SystemHeader.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { SITE } from "../config/site";
import {
  formatCompactDate,
  formatDate,
  getTopicRoute,
  getPostRoute,
  getPostSlug,
  getRelatedPosts,
  readingTime,
  sortPosts,
  wordCount,
  type BlogPost,
} from "../utils/posts";
import BaseLayout from "./BaseLayout.astro";
import "../styles/system.css";
import "../styles/article.css";

interface Props {
  post: BlogPost;
  headings: MarkdownHeading[];
}

const { post, headings } = Astro.props;
const hasToc = headings.some(({ depth }) => depth === 2 || depth === 3);
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = sortPosts(allPosts);
const relatedPosts = getRelatedPosts(post, sortedPosts);
const currentPostIndex = sortedPosts.findIndex(({ id }) => id === post.id);
const newerPost =
  currentPostIndex > 0 ? sortedPosts[currentPostIndex - 1] : undefined;
const olderPost =
  currentPostIndex >= 0 && currentPostIndex < sortedPosts.length - 1
    ? sortedPosts[currentPostIndex + 1]
    : undefined;
const description = post.data.description;
const articleUrl = new URL(
  getPostRoute(post),
  Astro.site ?? new URL(SITE.url),
).href;

const year = post.data.date.getUTCFullYear();
const month = String(post.data.date.getUTCMonth() + 1).padStart(2, "0");
const day = String(post.data.date.getUTCDate()).padStart(2, "0");
const docId = `LOG-${year}${month}${day}-${getPostSlug(post)
  .slice(0, 12)
  .toUpperCase()}`;
const publishedDate = post.data.date.toISOString();
const modifiedDate = (post.data.updatedDate ?? post.data.date).toISOString();
const structuredData = [
  {
    "@type": "BlogPosting",
    "@id": `${articleUrl}#article`,
    headline: post.data.title,
    description,
    url: articleUrl,
    mainEntityOfPage: articleUrl,
    datePublished: publishedDate,
    dateModified: modifiedDate,
    inLanguage: SITE.language,
    articleSection: post.data.topic,
    keywords: post.data.keywords.join(", "),
    wordCount: wordCount(post.body ?? ""),
    author: { "@id": `${SITE.url}/#person` },
    publisher: { "@id": `${SITE.url}/#person` },
    isPartOf: { "@id": `${SITE.url}/#website` },
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: SITE.url,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Posts",
        item: `${SITE.url}/posts/`,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: post.data.topic,
        item: new URL(getTopicRoute(post.data.topic), SITE.url).href,
      },
      {
        "@type": "ListItem",
        position: 4,
        name: post.data.title,
        item: articleUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={post.data.title}
  description={description}
  structuredData={structuredData}
  article
>
  <Fragment slot="head">
    <meta property="article:published_time" content={publishedDate} />
    <meta property="article:modified_time" content={modifiedDate} />
    <meta property="article:section" content={post.data.topic} />
    {post.data.keywords.map((keyword) => (
      <meta property="article:tag" content={keyword} />
    ))}
  </Fragment>

  <div class="system-page-shell article-page-shell">
    <SystemHeader active="posts" />
    <div class="reading-progress" aria-hidden="true">
      <span data-reading-progress></span>
    </div>

    <section class="article-console" aria-labelledby="article-title">
      <header class="article-system-header">
        <p class="article-doc-strip">DOCUMENT / {docId}</p>
        <h1 id="article-title" class="article-title p-name">
          {post.data.title}
        </h1>

        <p class="article-description">{description}</p>

        <div class="post-meta" aria-label="Document metadata">
          <time class="dt-published" datetime={publishedDate}>
            {formatDate(post.data.date)}
          </time>
          <span aria-hidden="true">·</span>
          <span>{readingTime(post.body ?? "")} min read</span>
          {post.data.updatedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>updated {formatDate(post.data.updatedDate)}</span>
            </>
          )}
        </div>

        <div class="post-taxonomy" aria-label="Post classification">
          <p class="post-topic">
            <span>TOPIC</span>
            <a href={getTopicRoute(post.data.topic)}>
              {post.data.topic}
            </a>
          </p>
        </div>
      </header>

      <div class:list={["post-layout", { "no-toc": !hasToc }]}>
        {hasToc && <TableOfContents headings={headings} />}

        <article class="post h-entry article-sheet">
          <div class="post-content e-content">
            <slot />
          </div>
        </article>
      </div>

      {relatedPosts.length > 0 && (
        <section class="related-posts" aria-labelledby="related-posts-title">
          <header>
            <p class="article-doc-strip">RELATED / SAME SYSTEM</p>
            <h2 id="related-posts-title">Continue reading</h2>
          </header>
          <ol>
            {relatedPosts.map((relatedPost) => (
              <li>
                <time datetime={relatedPost.data.date.toISOString()}>
                  {formatCompactDate(relatedPost.data.date)}
                </time>
                <div>
                  <a href={getPostRoute(relatedPost)}>
                    {relatedPost.data.title}
                  </a>
                  <span>{relatedPost.data.topic}</span>
                </div>
              </li>
            ))}
          </ol>
        </section>
      )}

      <nav class="post-navigation" aria-label="More notes">
        <a class="post-navigation-topic" href={getTopicRoute(post.data.topic)}>
          ← ALL {post.data.topic.toUpperCase()} NOTES
        </a>

        {(newerPost || olderPost) && (
          <div class="post-navigation-chronology">
            {newerPost && (
              <a href={getPostRoute(newerPost)}>
                <span>NEWER NOTE</span>
                <strong>{newerPost.data.title}</strong>
              </a>
            )}
            {olderPost && (
              <a href={getPostRoute(olderPost)}>
                <span>OLDER NOTE</span>
                <strong>{olderPost.data.title}</strong>
              </a>
            )}
          </div>
        )}
      </nav>

      <footer class="article-system-footer">
        <a href="/posts/">LOG ARCHIVE</a>
        <span>{docId}</span>
        <a href="/">TERMINAL HOME</a>
      </footer>
    </section>
  </div>

  <BackToTop />

  <script>
    let removeArticleUx = () => {};

    function initArticleUx() {
      removeArticleUx();

      const cleanupFunctions: Array<() => void> = [];
      const layout = document.querySelector<HTMLElement>(".post-layout");
      const article = document.querySelector<HTMLElement>(".article-sheet");
      const content = article?.querySelector<HTMLElement>(".post-content");

      const progress = document.querySelector<HTMLElement>(
        "[data-reading-progress]",
      );

      if (progress && article) {
        let progressFrame: number | null = null;

        const updateProgress = () => {
          progressFrame = null;
          const articleTop =
            article.getBoundingClientRect().top + window.scrollY;
          const articleEnd = articleTop + article.offsetHeight;
          const readableDistance = Math.max(
            articleEnd - articleTop - window.innerHeight * 0.35,
            1,
          );
          const amount = Math.min(
            1,
            Math.max(0, (window.scrollY - articleTop) / readableDistance),
          );

          progress.style.transform = `scaleX(${amount})`;
        };

        const requestProgressUpdate = () => {
          if (progressFrame === null) {
            progressFrame = window.requestAnimationFrame(updateProgress);
          }
        };

        window.addEventListener("scroll", requestProgressUpdate, {
          passive: true,
        });
        window.addEventListener("resize", requestProgressUpdate);
        updateProgress();

        cleanupFunctions.push(() => {
          window.removeEventListener("scroll", requestProgressUpdate);
          window.removeEventListener("resize", requestProgressUpdate);
          if (progressFrame !== null) {
            window.cancelAnimationFrame(progressFrame);
          }
        });
      }

      if (layout && content) {
        const desktopToc = layout.querySelector<HTMLElement>(".toc-desktop");
        const mobileToc = layout.querySelector<HTMLDetailsElement>(".toc-mobile");
        const links = Array.from(
          layout.querySelectorAll<HTMLAnchorElement>("[data-toc-link]"),
        );
        const groupedEntries = new Map<
          string,
          { heading: HTMLElement; links: HTMLAnchorElement[] }
        >();

        for (const link of links) {
          let id: string;

          try {
            id = decodeURIComponent(link.hash.slice(1));
          } catch {
            continue;
          }

          const heading = content.querySelector<HTMLElement>(
            `#${CSS.escape(id)}`,
          );
          if (!heading) continue;

          const existing = groupedEntries.get(id);
          if (existing) {
            existing.links.push(link);
          } else {
            groupedEntries.set(id, { heading, links: [link] });
          }
        }

        const entries = Array.from(groupedEntries.values());

        if (entries.length > 0) {
          const reducedMotion = window.matchMedia(
            "(prefers-reduced-motion: reduce)",
          );
          let activeId = "";
          let tocFrame: number | null = null;

          const keepLinkVisible = (link: HTMLAnchorElement) => {
            if (!desktopToc || !desktopToc.contains(link)) return;

            const padding = 12;
            const tocRect = desktopToc.getBoundingClientRect();
            const linkRect = link.getBoundingClientRect();
            const behavior: ScrollBehavior = reducedMotion.matches
              ? "auto"
              : "smooth";

            if (linkRect.top < tocRect.top + padding) {
              desktopToc.scrollBy({
                top: linkRect.top - tocRect.top - padding,
                behavior,
              });
            } else if (linkRect.bottom > tocRect.bottom - padding) {
              desktopToc.scrollBy({
                top: linkRect.bottom - tocRect.bottom + padding,
                behavior,
              });
            }
          };

          const setActive = (id: string) => {
            if (id === activeId) return;
            activeId = id;

            for (const entry of entries) {
              const active = entry.heading.id === id;

              for (const link of entry.links) {
                link.classList.toggle("is-active", active);
                if (active) {
                  link.setAttribute("aria-current", "location");
                } else {
                  link.removeAttribute("aria-current");
                }
              }

              if (active) {
                const desktopLink = entry.links.find((link) =>
                  desktopToc?.contains(link),
                );
                if (desktopLink) keepLinkVisible(desktopLink);
              }
            }
          };

          const updateActiveSection = () => {
            tocFrame = null;
            const readingOffset = 150;
            const atDocumentBottom =
              window.scrollY + window.innerHeight >=
              document.documentElement.scrollHeight - 4;
            let current = entries[0];

            if (atDocumentBottom) {
              current = entries[entries.length - 1];
            } else {
              for (const entry of entries) {
                if (
                  entry.heading.getBoundingClientRect().top <= readingOffset
                ) {
                  current = entry;
                } else {
                  break;
                }
              }
            }

            setActive(current.heading.id);
          };

          const requestTocUpdate = () => {
            if (tocFrame === null) {
              tocFrame = window.requestAnimationFrame(updateActiveSection);
            }
          };

          const mobileLinkHandlers = links
            .filter((link) => mobileToc?.contains(link))
            .map((link) => {
              const handler = () => {
                if (mobileToc) mobileToc.open = false;
              };
              link.addEventListener("click", handler);
              return { link, handler };
            });

          window.addEventListener("scroll", requestTocUpdate, {
            passive: true,
          });
          window.addEventListener("resize", requestTocUpdate);
          updateActiveSection();

          cleanupFunctions.push(() => {
            window.removeEventListener("scroll", requestTocUpdate);
            window.removeEventListener("resize", requestTocUpdate);
            if (tocFrame !== null) window.cancelAnimationFrame(tocFrame);

            for (const { link, handler } of mobileLinkHandlers) {
              link.removeEventListener("click", handler);
            }
          });
        }
      }

      if (content) {
        const copyButtons: Array<{
          button: HTMLButtonElement;
          handler: () => void;
        }> = [];

        const copyText = async (text: string) => {
          if (!navigator.clipboard?.writeText) {
            throw new Error("Clipboard API unavailable");
          }

          await navigator.clipboard.writeText(text);
        };

        for (const pre of content.querySelectorAll<HTMLPreElement>("pre")) {
          if (pre.dataset.copyEnhanced === "true") continue;
          pre.dataset.copyEnhanced = "true";

          const wrapper = document.createElement("div");
          wrapper.className = "code-block";
          pre.before(wrapper);
          wrapper.append(pre);

          const button = document.createElement("button");
          button.className = "code-copy-button";
          button.type = "button";
          button.textContent = "COPY";
          button.setAttribute("aria-label", "Copy code to clipboard");
          wrapper.prepend(button);

          const handler = async () => {
            const code = pre.querySelector("code")?.textContent ?? pre.textContent;
            try {
              await copyText(code ?? "");
              button.textContent = "COPIED";
            } catch {
              button.textContent = "FAILED";
            }

            window.setTimeout(() => {
              button.textContent = "COPY";
            }, 1400);
          };

          button.addEventListener("click", handler);
          copyButtons.push({ button, handler });
        }

        cleanupFunctions.push(() => {
          for (const { button, handler } of copyButtons) {
            button.removeEventListener("click", handler);
          }
        });
      }

      removeArticleUx = () => {
        for (const cleanup of cleanupFunctions) cleanup();
      };
    }

    initArticleUx();
    document.addEventListener("astro:page-load", initArticleUx);
    document.addEventListener("astro:before-swap", () => removeArticleUx());
  </script>
</BaseLayout>
