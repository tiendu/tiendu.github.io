---
import type { MarkdownHeading } from "astro";
import { getCollection } from "astro:content";
import BackToTop from "../components/BackToTop.astro";
import SystemHeader from "../components/SystemHeader.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { SITE } from "../config/site";
import {
  formatCompactDate,
  formatDate,
  getTopicRoute,
  getPostRoute,
  getPostSlug,
  getRelatedPosts,
  readingTime,
  wordCount,
  type BlogPost,
} from "../utils/posts";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  post: BlogPost;
  headings: MarkdownHeading[];
}

const { post, headings } = Astro.props;
const hasToc = headings.some(({ depth }) => depth === 2 || depth === 3);
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const relatedPosts = getRelatedPosts(post, allPosts);
const description = post.data.description;
const articleUrl = new URL(
  getPostRoute(post),
  Astro.site ?? new URL(SITE.url),
).href;

const year = post.data.date.getUTCFullYear();
const month = String(post.data.date.getUTCMonth() + 1).padStart(2, "0");
const day = String(post.data.date.getUTCDate()).padStart(2, "0");
const docId = `LOG-${year}${month}${day}-${getPostSlug(post)
  .slice(0, 12)
  .toUpperCase()}`;
const publishedDate = post.data.date.toISOString();
const modifiedDate = (post.data.updatedDate ?? post.data.date).toISOString();
const structuredData = [
  {
    "@type": "BlogPosting",
    "@id": `${articleUrl}#article`,
    headline: post.data.title,
    description,
    url: articleUrl,
    mainEntityOfPage: articleUrl,
    datePublished: publishedDate,
    dateModified: modifiedDate,
    inLanguage: SITE.language,
    articleSection: post.data.topic,
    keywords: post.data.keywords.join(", "),
    wordCount: wordCount(post.body ?? ""),
    author: { "@id": `${SITE.url}/#person` },
    publisher: { "@id": `${SITE.url}/#person` },
    isPartOf: { "@id": `${SITE.url}/#website` },
  },
  {
    "@type": "BreadcrumbList",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: SITE.url,
      },
      {
        "@type": "ListItem",
        position: 2,
        name: "Posts",
        item: `${SITE.url}/posts/`,
      },
      {
        "@type": "ListItem",
        position: 3,
        name: post.data.topic,
        item: new URL(getTopicRoute(post.data.topic), SITE.url).href,
      },
      {
        "@type": "ListItem",
        position: 4,
        name: post.data.title,
        item: articleUrl,
      },
    ],
  },
];
---

<BaseLayout
  title={post.data.title}
  description={description}
  structuredData={structuredData}
  article
>
  <Fragment slot="head">
    <meta property="article:published_time" content={publishedDate} />
    <meta property="article:modified_time" content={modifiedDate} />
    <meta property="article:section" content={post.data.topic} />
    {post.data.keywords.map((keyword) => (
      <meta property="article:tag" content={keyword} />
    ))}
  </Fragment>

  <div class="system-page-shell article-page-shell">
    <SystemHeader active="posts" />

    <section class="article-console" aria-labelledby="article-title">
      <header class="article-system-header">
        <p class="article-doc-strip">DOCUMENT / {docId}</p>
        <h1 id="article-title" class="article-title p-name">
          {post.data.title}
        </h1>

        <p class="article-description">{description}</p>

        <div class="post-meta" aria-label="Document metadata">
          <time class="dt-published" datetime={publishedDate}>
            {formatDate(post.data.date)}
          </time>
          <span aria-hidden="true">·</span>
          <span>{readingTime(post.body ?? "")} min read</span>
          {post.data.updatedDate && (
            <>
              <span aria-hidden="true">·</span>
              <span>updated {formatDate(post.data.updatedDate)}</span>
            </>
          )}
        </div>

        <div class="post-taxonomy" aria-label="Post classification">
          <p class="post-topic">
            <span>TOPIC</span>
            <a href={getTopicRoute(post.data.topic)}>
              {post.data.topic}
            </a>
          </p>
        </div>
      </header>

      <div class:list={["post-layout", { "no-toc": !hasToc }]}>
        {hasToc && <TableOfContents headings={headings} />}

        <article class="post h-entry article-sheet">
          <div class="post-content e-content">
            <slot />
          </div>
        </article>
      </div>

      {relatedPosts.length > 0 && (
        <section class="related-posts" aria-labelledby="related-posts-title">
          <header>
            <p class="article-doc-strip">RELATED / SAME SYSTEM</p>
            <h2 id="related-posts-title">Continue reading</h2>
          </header>
          <ol>
            {relatedPosts.map((relatedPost) => (
              <li>
                <time datetime={relatedPost.data.date.toISOString()}>
                  {formatCompactDate(relatedPost.data.date)}
                </time>
                <div>
                  <a href={getPostRoute(relatedPost)}>
                    {relatedPost.data.title}
                  </a>
                  <span>{relatedPost.data.topic}</span>
                </div>
              </li>
            ))}
          </ol>
        </section>
      )}

      <footer class="article-system-footer">
        <a href="/posts/">LOG ARCHIVE</a>
        <span>{docId}</span>
        <a href="/">TERMINAL HOME</a>
      </footer>
    </section>
  </div>

  <BackToTop />

  <script>
    let removeTocScrollSpy = () => {};

    function initTocScrollSpy() {
      removeTocScrollSpy();

      const layout = document.querySelector<HTMLElement>(".post-layout");
      const toc = layout?.querySelector<HTMLElement>(".toc");
      const article = layout?.querySelector<HTMLElement>(".post-content");

      if (!toc || !article) return;

      const tocElement = toc;
      const links = Array.from(
        tocElement.querySelectorAll<HTMLAnchorElement>('a[href^="#"]'),
      );

      const entries = links
        .map((link) => {
          let id: string;

          try {
            id = decodeURIComponent(link.hash.slice(1));
          } catch {
            return null;
          }

          const heading = article.querySelector<HTMLElement>(
            `#${CSS.escape(id)}`,
          );

          return heading ? { link, heading } : null;
        })
        .filter(
          (
            entry,
          ): entry is {
            link: HTMLAnchorElement;
            heading: HTMLElement;
          } => entry !== null,
        );

      if (entries.length === 0) return;

      const reducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      );

      let activeId = "";
      let frame: number | null = null;

      function keepLinkVisible(link: HTMLAnchorElement) {
        const padding = 12;
        const tocRect = tocElement.getBoundingClientRect();
        const linkRect = link.getBoundingClientRect();
        const behavior: ScrollBehavior = reducedMotion.matches
          ? "auto"
          : "smooth";

        if (linkRect.top < tocRect.top + padding) {
          tocElement.scrollBy({
            top: linkRect.top - tocRect.top - padding,
            behavior,
          });
        } else if (linkRect.bottom > tocRect.bottom - padding) {
          tocElement.scrollBy({
            top: linkRect.bottom - tocRect.bottom + padding,
            behavior,
          });
        }
      }

      function setActive(id: string) {
        if (id === activeId) return;

        activeId = id;

        for (const { link, heading } of entries) {
          const active = heading.id === id;
          link.classList.toggle("is-active", active);

          if (active) {
            link.setAttribute("aria-current", "location");
            keepLinkVisible(link);
          } else {
            link.removeAttribute("aria-current");
          }
        }
      }

      function updateActiveSection() {
        frame = null;
        const readingOffset = 150;
        const atDocumentBottom =
          window.scrollY + window.innerHeight >=
          document.documentElement.scrollHeight - 4;

        let current = entries[0];

        if (atDocumentBottom) {
          current = entries[entries.length - 1];
        } else {
          for (const entry of entries) {
            if (entry.heading.getBoundingClientRect().top <= readingOffset) {
              current = entry;
            } else {
              break;
            }
          }
        }

        setActive(current.heading.id);
      }

      function requestUpdate() {
        if (frame === null) {
          frame = window.requestAnimationFrame(updateActiveSection);
        }
      }

      window.addEventListener("scroll", requestUpdate, { passive: true });
      window.addEventListener("resize", requestUpdate);
      updateActiveSection();

      removeTocScrollSpy = () => {
        window.removeEventListener("scroll", requestUpdate);
        window.removeEventListener("resize", requestUpdate);

        if (frame !== null) {
          window.cancelAnimationFrame(frame);
          frame = null;
        }

        for (const { link } of entries) {
          link.classList.remove("is-active");
          link.removeAttribute("aria-current");
        }
      };
    }

    initTocScrollSpy();
    document.addEventListener("astro:page-load", initTocScrollSpy);
    document.addEventListener("astro:before-swap", () => removeTocScrollSpy());
  </script>
</BaseLayout>
